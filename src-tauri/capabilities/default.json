{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-size",
    "core:window:allow-set-resizable",
    "core:window:allow-set-maximizable",
    "core:window:allow-center",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "code",
          "cmd": "code",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "open-terminal",
          "cmd": "open",
          "args": [
            "-a",
            "Terminal",
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "open-finder",
          "cmd": "open",
          "args": [
            "-R",
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "open-app",
          "cmd": "open",
          "args": [
            "-a",
            {
              "validator": "[A-Za-z][\\w\\s.-]+"
            },
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "cursor-cli",
          "cmd": "cursor",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "zed-cli",
          "cmd": "zed",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "subl-cli",
          "cmd": "subl",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "windsurf-cli",
          "cmd": "windsurf",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "xdg-open",
          "cmd": "xdg-open",
          "args": [
            {
              "validator": "[/~.][-\\w\\s./~]+"
            }
          ]
        },
        {
          "name": "explorer-select",
          "cmd": "explorer",
          "args": [
            "/select,",
            {
              "validator": "[A-Za-z]:?[\\\\/ ][-\\w\\s./\\\\~:]+"
            }
          ]
        },
        {
          "name": "explorer-open",
          "cmd": "explorer",
          "args": [
            {
              "validator": "[A-Za-z]:?[\\\\/ ][-\\w\\s./\\\\~:]+"
            }
          ]
        }
      ]
    },
    "updater:default",
    "process:allow-restart",
    "process:allow-exit",
    "window-state:default",
    "dialog:default",
    "notification:default",
    "notification:allow-notify",
    "notification:allow-request-permission",
    "pty:default",
    "pty:allow-spawn",
    "pty:allow-read",
    "pty:allow-write",
    "pty:allow-resize",
    "pty:allow-kill",
    "pty:allow-exitstatus",
    "mcp-bridge:default",
    "deep-link:default",
    "stronghold:default",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-image",
    "core:image:allow-rgba",
    "core:image:allow-size"
  ]
}
